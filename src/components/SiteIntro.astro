---
import { site } from "@data/site";
import ContactBar from "./ContactBar.astro";
import { Icon } from "astro-icon/components";

interface Props {
  variant: "sidebar" | "mobile";
}

const { variant } = Astro.props;
const isSidebar = variant === "sidebar";
---

{
  isSidebar ? (
    <div class="mb-4 flex flex-col items-center text-center">
      <a
        href={import.meta.env.BASE_URL}
        class="text-5xl font-bold tracking-tight text-white transition font-heading hover:text-accent"
      >
        {site.hero.name}
      </a>
      <p class="mt-4 text-xl font-medium text-accent/90">{site.hero.role}</p>

      <div class="mt-4 max-w-xs space-y-4">
        <p class="body-copy text-[12px] text-slate-light/80 italic">
          {site.hero.domicile}
        </p>
        <p class="body-copy text-slate-light">{site.hero.tagline}</p>
      </div>

      <div class="flex justify-center">
        <ContactBar />
      </div>

      <div class="mt-4">
        <a
          href={site.contact.resumeUrl}
          download
          class="inline-flex items-center gap-2 rounded-md border border-accent/30 bg-accent/5 px-5 py-2.5 font-mono text-xs uppercase tracking-[0.15em] text-accent transition-all duration-300 hover:border-accent hover:bg-accent hover:text-background hover:shadow-[0_0_15px_rgba(var(--color-accent),0.2)]"
        >
          <Icon name="ph:download-simple" class="h-4 w-4" />
          Download Resume
        </a>
      </div>
    </div>
  ) : (
    <div class="flex flex-col items-center justify-center text-center w-full max-w-full mx-auto">
      <h1 class="text-4xl font-bold tracking-tight text-white font-heading">
        {site.hero.name}
      </h1>
      <p class="mt-2 text-lg font-semibold text-accent">{site.hero.role}</p>

      <div class="mt-4 max-w-prose space-y-2 text-base text-slate-light">
        <p>{site.hero.tagline}</p>
      </div>

      <div class="mt-6 flex flex-col items-center justify-center gap-4 w-full">
        <ContactBar />

        <a
          href={site.contact.resumeUrl}
          download
          class="inline-flex items-center gap-2 rounded-md border border-accent/30 bg-accent/5 px-4 py-2 font-mono text-[10px] uppercase tracking-[0.15em] text-accent transition-all hover:border-accent hover:bg-accent hover:text-background"
        >
          <Icon name="ph:download-simple" class="h-3.5 w-3.5" />
          Resume
        </a>
      </div>
    </div>
  )
}
